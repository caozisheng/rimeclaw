{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 25,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "cacheVariables": {
        "CMAKE_TOOLCHAIN_FILE": {
          "type": "FILEPATH",
          "value": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake"
        },
        "CMAKE_BUILD_TYPE": "Release",
        "VCPKG_MANIFEST_DIR": "${sourceDir}/3rd"
      }
    },
    {
      "name": "build-lib",
      "displayName": "Build Library Only",
      "description": "Build librimeclaw only (core dependencies)",
      "inherits": "base",
      "binaryDir": "${sourceDir}/build-lib",
      "cacheVariables": {
        "VCPKG_INSTALLED_DIR": "${sourceDir}/build-lib/installed",
        "BUILD_TEST": "OFF",
        "BUILD_DASHBOARD": "OFF"
      }
    },
    {
      "name": "build-test",
      "displayName": "Build Library + Test",
      "description": "Build librimeclaw and test executable",
      "inherits": "base",
      "binaryDir": "${sourceDir}/build-test",
      "cacheVariables": {
        "VCPKG_INSTALLED_DIR": "${sourceDir}/build-test/installed",
        "BUILD_TEST": "ON",
        "BUILD_DASHBOARD": "OFF"
      }
    },
    {
      "name": "build-dashboard",
      "displayName": "Build Library + Dashboard",
      "description": "Build librimeclaw and dashboard GUI",
      "inherits": "base",
      "binaryDir": "${sourceDir}/build-dashboard",
      "cacheVariables": {
        "VCPKG_INSTALLED_DIR": "${sourceDir}/build-dashboard/installed",
        "BUILD_TEST": "OFF",
        "BUILD_DASHBOARD": "ON"
      }
    },
    {
      "name": "build-all",
      "displayName": "Build All",
      "description": "Build librimeclaw, test, and dashboard",
      "inherits": "base",
      "binaryDir": "${sourceDir}/build-all",
      "cacheVariables": {
        "VCPKG_INSTALLED_DIR": "${sourceDir}/build-all/installed",
        "BUILD_TEST": "ON",
        "BUILD_DASHBOARD": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "build-lib",
      "displayName": "Build Library Only",
      "configurePreset": "build-lib"
    },
    {
      "name": "build-test",
      "displayName": "Build Library + Test",
      "configurePreset": "build-test"
    },
    {
      "name": "build-dashboard",
      "displayName": "Build Library + Dashboard",
      "configurePreset": "build-dashboard"
    },
    {
      "name": "build-all",
      "displayName": "Build All",
      "configurePreset": "build-all"
    }
  ]
}
